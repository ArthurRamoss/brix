# Copie este arquivo pra `.env.local` e preencha com suas chaves.
# .env.local é ignorado pelo git. Nunca commite chaves reais.

# ============================================================
# Research / Colosseum
# ============================================================
COLOSSEUM_COPILOT_API_BASE=https://copilot.colosseum.com/api/v1
COLOSSEUM_COPILOT_PAT=replace_with_your_token

# ============================================================
# Solana RPC — Helius (sponsor Frontier, free tier devnet)
# https://dashboard.helius.dev
# ============================================================
HELIUS_API_KEY=replace_with_your_key
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# ============================================================
# Privy — auth + embedded wallet (sponsor Frontier)
# https://dashboard.privy.io
# ============================================================
NEXT_PUBLIC_PRIVY_APP_ID=replace_with_your_app_id

# ============================================================
# Brix program
# (preenchido após `anchor deploy` no CP1)
# ============================================================
NEXT_PUBLIC_BRIX_PROGRAM_ID=replace_after_deploy

# ============================================================
# BRZ stablecoin (Transfero) — opcional pra dev local
# Mainnet mint: FtgGSFADXBtroxq8VCausXRr2of47QBf5AS1NtZCu4GD
# Em devnet: use um mint próprio (criado no setup) ou mock
# ============================================================
NEXT_PUBLIC_BRZ_MINT=replace_with_devnet_or_mainnet_mint
