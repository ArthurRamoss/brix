  "types": [
    {
      "name": "InvestorPosition",
      "docs": [
        "Per-investor share ledger. One PDA per (vault, investor) pair.",
        "",
        "PDA seeds: [b\"position\", vault.key(), investor.key()]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "investor",
            "docs": [
              "The investor wallet (Privy-managed or external) that owns this position."
